# Backend URLs for the browser client.
#
# Default: leave these EMPTY to use Vite's same-origin dev proxy (vite.config.ts).
# The app then calls /api and /socket.io on its own origin and Vite forwards them
# to the backends on localhost — so it works on localhost AND from another device
# on your LAN (phone) with no CORS and no hardcoded IP.
VITE_API_URL=
VITE_WS_URL=
#
# Example values — set absolute URLs ONLY to target a remote/separate backend
# (that backend must then allow this origin via CORS). This also bypasses the
# proxy, so leave them empty for the LAN setup above.
#   VITE_API_URL=http://localhost:3001    # santa-api (NestJS)
#   VITE_WS_URL=http://localhost:3002     # santa-notifications (Fastify + Socket.IO)
