# Dev image — all deps + watch mode (hot reload via nodemon).
# Source is bind-mounted via docker-compose.dev.yml, so edits on the host trigger
# the in-container watcher and the server restarts. NOT for production.
FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
EXPOSE 3002
CMD ["npm", "run", "dev"]
