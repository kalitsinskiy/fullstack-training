{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "globalSetup": "<rootDir>/global-setup.ts",
  "globalTeardown": "<rootDir>/global-teardown.ts",
  "setupFilesAfterEnv": ["<rootDir>/setup-mongo.ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
